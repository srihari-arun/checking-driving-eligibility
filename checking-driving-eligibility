            print("The candidate is not eligible to drive due to old age. Pass for old age driving test to renew driving license.")
        elif age < min_age:
            print("The candidate is too young and thus not eligible to drive")
        else:
            has_license = input("Does the candidate have a driving license or permit? ").upper()
            valid_yes = {"YES", "Y", "TRUE", "T"}
            valid_no = {"NO", "N", "F", "FALSE"}

            if has_license in valid_yes:
                print("The candidate is eligible to drive in", country.upper())
            elif has_license in valid_no:
                print("The candidate is not eligible to drive in", country.upper())
            else:
                print("INVALID INPUT. Please provide valid input")

    except ValueError:
